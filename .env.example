# ─── Image generation (stable-diffusion.cpp / llama-swap) ──────────────────
IMAGE_API_BASE_URL=http://localhost:4134
IMAGE_API_KEY=
# Model name sent in the request body
IMAGE_MODEL=flux-klein
# Supported resolutions: square, portrait, landscape
IMAGE_SIZE_SQUARE=1024x1024
IMAGE_SIZE_PORTRAIT=896x1536
IMAGE_SIZE_LANDSCAPE=1536x896

# ─── Music generation (ACE Step CPP UI) ────────────────────────────────────
MUSIC_API_BASE_URL=http://localhost:3005
MUSIC_API_KEY=
# Sampling parameters for ACE Step
MUSIC_GUIDANCE_SCALE=9
MUSIC_INFERENCE_STEPS=12
MUSIC_LM_CFG_SCALE=2.2
MUSIC_LM_TEMPERATURE=0.8
MUSIC_LM_TOP_P=0.92
MUSIC_SHIFT=3

# ─── Asset storage ─────────────────────────────────────────────────────────
# Absolute path to the folder where generated files are saved on disk
ASSETS_DIR=/tmp/media-mcp-assets

# ─── Response format ───────────────────────────────────────────────────────
# "path"   → return the saved file path  (default)
# "base64" → return the raw base64-encoded content inline
RESPONSE_FORMAT=path

# ─── MCP Server Transport ──────────────────────────────────────────────────
# The host and port where this MCP server will listen for streamable-http connections
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ─── Misc ──────────────────────────────────────────────────────────────────
# Per-request timeout in seconds (music generation can take several minutes)
REQUEST_TIMEOUT=300
MUSIC_JWT_SECRET=super-secret